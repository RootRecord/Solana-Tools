METEORA_DAMM_V2_API_URL=https://dammv2-api.meteora.ag
ORCA_API_URL=https://api.orca.so/v2/solana
HTTP_TIMEOUT_SECONDS=20

# Common LP action inputs.
INPUT_MINT=So11111111111111111111111111111111111111112
OUTPUT_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
TOKEN_MINT=replace_with_token_mint
RAW_AMOUNT=1000000
SLIPPAGE_BPS=50
TX_VERSION=V0
PAGE=1
PAGE_SIZE=20

# TypeScript SDK action inputs for flows that need official SDKs.
TOKEN_NAME=Example Token
TOKEN_SYMBOL=EXMPL
TOKEN_DECIMALS=6
TOKEN_SUPPLY_RAW=1000000000000000
TOKEN_METADATA_URI=https://example.com/metadata.json
QUOTE_MINT=So11111111111111111111111111111111111111112

# Raydium LaunchLab SDK.
RAYDIUM_LAUNCHPAD_PROGRAM_ID=
