# Copy to .env and fill in local values.
# Never commit .env with real private keys or API keys.

SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SEND_TRANSACTION=false

SOLANA_ACTIVE_PRIVATE_KEY_BASE58=replace_with_active_wallet_private_key
SOLANA_OLD_PRIVATE_KEY_BASE58=replace_with_previous_authority_private_key

# Optional local labels and watchlists for people managing more than one wallet or token.
ACTIVE_WALLET_LABEL=Primary Wallet
MANAGED_WALLET_PUBLIC_KEYS=
MANAGED_TOKEN_MINTS=

# Generic token action defaults.
DEFAULT_TOKEN_MINT=replace_with_token_mint
DEFAULT_OWNER_WALLET=replace_with_owner_wallet
DEFAULT_DESTINATION_WALLET=replace_with_destination_wallet
DEFAULT_NEW_AUTHORITY=replace_with_new_authority_wallet
DEFAULT_TOKENS_TO_MINT=100
DEFAULT_TOKEN_DECIMALS=9
DEFAULT_THAW_ACCOUNTS=account_one,account_two,account_three

SPL_TOKEN_PROGRAM_ID=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
TOKEN_2022_PROGRAM_ID=TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb
