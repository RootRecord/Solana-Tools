# Raydium / LP / launchpad API defaults.
RAYDIUM_API_V3_URL=https://api-v3.raydium.io
RAYDIUM_TRANSACTION_URL=https://transaction-v1.raydium.io
LAUNCHLAB_MINT_URL=https://launch-mint-v1.raydium.io
LAUNCHLAB_HISTORY_URL=https://launch-history-v1.raydium.io
LAUNCHLAB_AUTH_URL=https://launch-auth-v1.raydium.io
